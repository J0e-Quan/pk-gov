{
  "name": "pk-gov",
  "version": "1.0.0",
  "type": "module",
  "description": "Fictional Plushie Kingdom government website",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "start": "npm-run-all --parallel dev:*",
    "dev:eleventy": "eleventy --serve",
    "dev:webpack": "webpack --watch --config webpack.dev.cjs --watch",
    "dev": "webpack serve --config webpack.dev.cjs",
    "build": "webpack --config webpack.prod.cjs && eleventy --incremental && npx pagefind --site dist",
    "deploy": "npm run cleanup && npm run test && npm run build && gh-pages -d dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "cleanup": "npm run format && npm run lint:fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/J0e-Quan/pk-gov.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/J0e-Quan/pk-gov/issues"
  },
  "homepage": "https://github.com/J0e-Quan/pk-gov#readme",
  "devDependencies": {
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.4.2",
    "mini-css-extract-plugin": "^2.10.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@supabase/supabase-js": "^2.108.2",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "lottie-web": "^5.13.0"
  },
  "allowScripts": {
    "sharp@0.33.5": true,
    "unrs-resolver@1.12.2": true
  }
}
