<!DOCTYPE html>
<html lang="en" class={{ page.fileSlug}}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href={{ "/assets/styles/ministries.css" | url }}>
    <link rel="icon" href="/assets/favicons/{{ page.fileSlug }}.svg"/>
    <title>{{ title }}</title>
  </head>
  <body>
   <header class="header">
      <a class="logo-text" href="/">
        <h3 class="logo-text top">Plushie Kingdom</h3>
        <h3 class="logo-text bottom">Government</h3>
      </a>
    </header>
    <section class="content">
      {{ content | safe }}
    </section>
    <a class="return" href="/">Return to homepage</a>
    <footer class="footer">
      <section class="footer-ministries">
        <h3 class="footer-title">Ministries</h3>
        <div class="footer-divider"></div>
        <div class="footer-ministries links">
          <a class="footer link" href="/ministries/central/">Central Ministry</a>
          <a class="footer link" href="/ministries/food/">Ministry of Food</a>
          <a class="footer link" href="/ministries/foreign-affairs/">Ministry of Foreign Affairs</a>
          <a class="footer link" href="/ministries/health/">Ministry of Health</a>
          <a class="footer link" href="/ministries/finance/">Ministry of Finance</a>
          <a class="footer link" href="/ministries/immigration/">Ministry of Immigration</a>
          <a class="footer link" href="/ministries/technology/">Ministry of Technology</a>
          <a class="footer link" href="/ministries/defence/">Ministry of Defence</a>
        </div>
      </section>
      <section class="footer-resources">
        <h3 class="footer-title">Other resources</h3>
        <div class="footer-divider"></div>
        <div class="footer-resources links">
          <a class="footer link" href="/info/">Life in the Plushie Kingdom</a>
          <a class="footer link" href="/news/">Government news</a>          
        </div>
      </section>
      <section class="footer-about">
        <h3 class="footer-title">About us</h3>
        <div class="footer-divider"></div>
        <div class="footer-resources links">
          <a class="footer link" href="/about/pk-gov/">About the pk-gov website</a>
          <a class="footer link" href="/info/who-we-are/#history-of-the-plushie-kingdom">History of the Plushie Kingdom</a>
          <a class="footer link" href="/about/gov-identity/">Government identity guidelines</a>          
        </div>
      </section>
    </footer>
    <script src="/{{ page.fileSlug }}.js"></script>
  </body>
</html>